# Copy to .env.local (not committed) for local dev.

# --- Route merge AI (optional) ---
# VITE_ROUTE_MERGE_AI_ENABLED=true
# VITE_AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.cognitiveservices.azure.com/openai
# VITE_AZURE_OPENAI_API_STYLE=azure-deployments
# VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o
# VITE_AZURE_OPENAI_MODEL=gpt-4o
# VITE_AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Browser-direct mode only (key is bundled if prefixed with VITE_ — avoid in public builds):
# VITE_AZURE_OPENAI_API_KEY=

# 生产 / Docker：与 routeMergeAi.useSameOriginProxy 配套（密钥不进浏览器、不写进 config.json）
# VITE_ROUTE_MERGE_AI_USE_SAME_ORIGIN_PROXY=true
# （容器内由 nginx 读取，非 Vite）
# TRV_ENABLE_ROUTE_MERGE_AI_PROXY=true
# TRV_AZURE_OPENAI_ORIGIN=https://YOUR_RESOURCE.cognitiveservices.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_API_KEY=

# Recommended with routeMergeAi.useDevProxy=true in config.json: key stays on dev server proxy
# AZURE_OPENAI_API_KEY=

# --- Azure OpenAI Node script (scripts/aoai-chat.mjs) ---
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-5.1
# AZURE_OPENAI_MODEL=gpt-5.1
