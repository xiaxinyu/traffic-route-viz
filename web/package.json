{
  "name": "traffic-route-viz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright:install": "PLAYWRIGHT_DOWNLOAD_CONNECTION_TIMEOUT=120000 playwright install chromium",
    "e2e": "playwright test --config playwright.config.cjs",
    "e2e:ui": "playwright test --config playwright.config.cjs --ui",
    "ci": "corepack pnpm run format:check && corepack pnpm run lint && corepack pnpm run typecheck && corepack pnpm run test && corepack pnpm run build && corepack pnpm run playwright:install && corepack pnpm run e2e"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@playwright/test": "1.53.0",
    "@biomejs/biome": "^2.4.14",
    "jsdom": "^26.1.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
